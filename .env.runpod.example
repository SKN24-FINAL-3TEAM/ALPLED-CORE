# ===== LLM / vLLM OpenAI-compatible API =====
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# ===== Qdrant =====
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_SRS_GLOSSARY=srs_glossary
QDRANT_COLLECTION_REQUIREMENT_REFERENCE=srs_requirement_reference
QDRANT_COLLECTION_REQUIREMENT_SOURCES=srs_requirement_sources
QDRANT_COLLECTION_REQUIREMENT_EXAMPLES=srs_requirement_examples

# ===== Eval =====
EVAL_CASES_PATH=eval/cases_erd.jsonl
EVAL_RESULT_DIR=eval/results
EVAL_TASK=erd